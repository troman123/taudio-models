# Local model/runtime caches (never commit weights)
.cache/
*.ckpt
*.pth
*.pt
*.onnx
*.safetensors
*.bin
*.so
*.dylib
*.dll

# User I/O for Docker compose (keep placeholders)
data/in/*
!data/in/.gitkeep
data/out/*
!data/out/.gitkeep

# Vendored native trees (optional local only; do not commit binaries)
libs/**/*
!libs/.gitkeep
!libs/**/README.md

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp
